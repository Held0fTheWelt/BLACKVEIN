{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session State Schema",
  "description": "Canonical schema for World Engine session state and metadata",
  "type": "object",
  "required": [
    "session_id",
    "module_id",
    "module_version",
    "contract_version",
    "prompt_version",
    "ai_backend",
    "ai_model",
    "created_at",
    "updated_at",
    "current_scene",
    "turn_number",
    "session_active"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique session identifier"
    },
    "module_id": {
      "type": "string",
      "description": "Content module identifier"
    },
    "module_version": {
      "type": "string",
      "description": "Version of loaded module"
    },
    "contract_version": {
      "type": "string",
      "description": "MVP contract version"
    },
    "prompt_version": {
      "type": "string",
      "description": "System prompt version for story LLM"
    },
    "ai_backend": {
      "type": "string",
      "description": "AI backend used (e.g., 'claude', 'ollama')"
    },
    "ai_model": {
      "type": "string",
      "description": "Specific AI model name"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 session creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last update timestamp"
    },
    "current_scene": {
      "type": "string",
      "description": "Current scene identifier"
    },
    "turn_number": {
      "type": "integer",
      "description": "Current turn counter",
      "minimum": 1
    },
    "session_active": {
      "type": "boolean",
      "description": "Whether session is in progress"
    },
    "seed": {
      "type": "string",
      "description": "Optional random seed for reproducibility"
    },
    "fallback_mode": {
      "type": "boolean",
      "description": "Whether engine is in reduced-resource fallback mode"
    },
    "recovery_attempt_count": {
      "type": "integer",
      "description": "Number of recovery retries",
      "minimum": 0
    }
  }
}
