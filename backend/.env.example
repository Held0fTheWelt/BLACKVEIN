# Required: set these before running (no default secrets in production)
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production-jwt

# Optional: use dev fallback secrets and allow seed-dev-user (local only)
# DEV_SECRETS_OK=0

# Flask (run backend from backend/ with FLASK_APP=run:app)
FLASK_APP=run:app
FLASK_DEBUG=0
PORT=5000

# Database (default: SQLite in backend/instance/wos.db)
# DATABASE_URI=sqlite:///...

# Backend: when set, GET / and GET /news redirect to the public frontend (no trailing slash).
# FRONTEND_URL=http://127.0.0.1:5001

# CORS: required when the frontend runs on a different origin than the backend.
# Comma-separated list of allowed origins. Empty = same-origin only.
# CORS_ORIGINS=http://127.0.0.1:5001,http://localhost:5001

# JWT
JWT_ACCESS_TOKEN_EXPIRES=86400

# Session cookies (production HTTPS)
# PREFER_HTTPS=0

# Rate limit
# RATELIMIT_DEFAULT=100 per minute
# RATELIMIT_STORAGE_URI=memory://

# Administration tool / local frontend
# BACKEND_API_URL=http://127.0.0.1:5000
# PORT=5001

# Mail (password reset and email verification)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=0
# MAIL_USE_SSL=0
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-password
MAIL_DEFAULT_SENDER=noreply@worldofshadows.local
# Set to 1 to send real mail; 0 = log URLs only (dev)
# MAIL_ENABLED=0

# Registration: 0 = email optional (default), 1 = email required and verification before login
# REGISTRATION_REQUIRE_EMAIL=0
# EMAIL_VERIFICATION_ENABLED=0

# Email verification: base URL for activation links (no trailing slash).
# If unset, activation links use the request host.
# APP_PUBLIC_BASE_URL=https://your-domain.com
# EMAIL_VERIFICATION_TTL_HOURS=24

# n8n integration
# N8N_WEBHOOK_URL=https://n8n.example.com/webhook/translate
# N8N_WEBHOOK_SECRET=change-me
# N8N_SERVICE_TOKEN=change-me

# Play service bridge
# Backend talks to the play service over PLAY_SERVICE_INTERNAL_URL.
# The browser connects to PLAY_SERVICE_PUBLIC_URL / WS derived from it.
# PLAY_SERVICE_INTERNAL_URL=http://127.0.0.1:8000
# PLAY_SERVICE_PUBLIC_URL=http://127.0.0.1:8000
# Must match the play service secret (world-engine: PLAY_SERVICE_SECRET or PLAY_SERVICE_SHARED_SECRET).
# PLAY_SERVICE_SHARED_SECRET=change-me
# Optional hardening for internal backend -> play-service calls.
# PLAY_SERVICE_INTERNAL_API_KEY=change-me
# GAME_TICKET_TTL_SECONDS=300
