# Required: set these before running (no default secrets in production)
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production-jwt

# Optional: use dev fallback secrets and allow seed-dev-user (local only)
# DEV_SECRETS_OK=0

# Content modules (YAML under <repo>/content/modules/). Set one of these if session start
# says "Module not found" for god_of_carnage — your process may not resolve the repo root.
# WOS_REPO_ROOT=C:\path\to\WorldOfShadows
# WOS_CONTENT_MODULES_ROOT=C:\path\to\WorldOfShadows\content\modules

# Flask (run backend from Backend/ with FLASK_APP=run:app)
FLASK_APP=run:app
FLASK_DEBUG=0
PORT=5000

# Database (default: SQLite in Backend/instance/wos.db)
# DATABASE_URI=sqlite:///...

# Backend: when set, legacy web routes (/login, /play, …) redirect to the player/public frontend (no trailing slash).
# Root GET / redirects to this service's /backend info pages, not to FRONTEND_URL.
# FRONTEND_URL=http://127.0.0.1:5002

# Optional: administration-tool base URL for clickable links on backend /backend home (no trailing slash).
# ADMINISTRATION_TOOL_URL=http://127.0.0.1:5001

# Optional: built MkDocs documentation site (no trailing slash) for deep links from /backend/* info pages.
# DOCS_SITE_URL=http://127.0.0.1:8000

# Optional: absolute path to openapi.yaml if not using default layout (custom deploy). Docker image includes docs/api/openapi.yaml under /app/docs/api/.
# OPENAPI_SPEC_PATH=

# CORS: required when the frontend or administration-tool runs on a different origin than the backend.
# Comma-separated list of allowed origins. Empty = same-origin only (browser will block cross-origin API calls).
# CORS_ORIGINS=http://127.0.0.1:5002,http://localhost:5002,http://127.0.0.1:5001,http://localhost:5001

# JWT
JWT_ACCESS_TOKEN_EXPIRES=86400

# Session cookies (production HTTPS)
# PREFER_HTTPS=0

# Rate limit
# RATELIMIT_DEFAULT=100 per minute

# Player/public frontend (run from frontend/ with: python run.py) — port 5002 by default
# BACKEND_API_URL=http://127.0.0.1:5000
# FRONTEND_PORT=5002

# Mail (password reset and email verification)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=0
# MAIL_USE_SSL=0
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-password
MAIL_DEFAULT_SENDER=noreply@worldofshadows.local
# Set to 1 to send real mail; 0 = log URLs only (dev)
# MAIL_ENABLED=0

# Email verification (0.0.7): base URL for activation links (no trailing slash).
# If unset, activation links use the request host.
# APP_PUBLIC_BASE_URL=https://your-domain.com
# EMAIL_VERIFICATION_TTL_HOURS=24


# Play service integration
# Backend -> play-service internal HTTP base URL (no trailing slash).
# Local world-engine default (see README / RUNBOOK): port 8001, not 8000.
# docker-compose sets http://play-service:8000 — that hostname works only inside the compose network.
# If Flask runs on the host and play-service is in Docker (port 8001 mapped), use http://127.0.0.1:8001
# for INTERNAL and PUBLIC; using play-service on the host causes connection refused (Errno 111).
# PLAY_SERVICE_INTERNAL_URL=http://127.0.0.1:8001
# Browser-visible play-service base URL (no trailing slash). Falls back to PLAY_SERVICE_INTERNAL_URL.
# PLAY_SERVICE_PUBLIC_URL=http://127.0.0.1:8001
# Shared HMAC secret used to sign short-lived play tickets.
# PLAY_SERVICE_SHARED_SECRET=replace-me-before-production
# Optional backend->play-service internal API key for /api/internal/* routes.
# PLAY_SERVICE_INTERNAL_API_KEY=replace-me-before-production
# GAME_TICKET_TTL_SECONDS=300

# Published authored game content feed consumed by the world-engine (optional)
# Public route: GET /api/v1/game-content/templates


# ==========================================
# OBSERVABILITY: Langfuse Configuration
# ==========================================
# NOTE: These settings are for INITIALIZATION ONLY.
# After docker-up.py initializes the system, credentials and configuration are GOVERNED
# by the Administration Tool (/manage/observability-settings) and stored encrypted in the database.
# The Administration Tool takes precedence over these environment variables for runtime.

# Enable Langfuse observability (default: false)
# LANGFUSE_ENABLED=false

# Langfuse API base URL (default: https://cloud.langfuse.com)
# For self-hosted Langfuse: http://localhost:3000
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Langfuse public key (pk_...)
# From https://cloud.langfuse.com/settings/api-keys
# LANGFUSE_PUBLIC_KEY=

# Langfuse secret key (sk_...) — REQUIRED if LANGFUSE_ENABLED=true
# From https://cloud.langfuse.com/settings/api-keys
# LANGFUSE_SECRET_KEY=

# Langfuse environment label (development|staging|production)
# LANGFUSE_ENVIRONMENT=development

# Release version for tracing (free-form, e.g., "1.0.0" or "git-abc123f")
# LANGFUSE_RELEASE=unknown

# Trace sampling rate (0.0-1.0; 0.0 = no traces, 1.0 = all traces)
# LANGFUSE_SAMPLE_RATE=1.0

# Capture toggles (what gets sent to Langfuse)
# LANGFUSE_CAPTURE_PROMPTS=true
# LANGFUSE_CAPTURE_OUTPUTS=true
# LANGFUSE_CAPTURE_RETRIEVAL=false

# Redaction policy (strict|relaxed|none)
# strict = maximum privacy (default)
# relaxed = fewer redactions
# none = no masking (test-only)
# LANGFUSE_REDACTION_MODE=strict
