# Required: set these before running (no default secrets in production)
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production-jwt

# Optional: use dev fallback secrets and allow seed-dev-user (local only)
# DEV_SECRETS_OK=0

# Flask
FLASK_APP=run.py
FLASK_DEBUG=0
PORT=5000

# Database (default: SQLite in instance folder)
# DATABASE_URI=sqlite:///instance/wos.db

# CORS: comma-separated origins for API (e.g. http://localhost:3000). Empty = same-origin only.
# CORS_ORIGINS=

# JWT
JWT_ACCESS_TOKEN_EXPIRES=86400

# Session cookies (production HTTPS)
# PREFER_HTTPS=0

# Rate limit
# RATELIMIT_DEFAULT=100 per minute
