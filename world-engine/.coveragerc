# World-engine pytest-cov configuration (see tests/run_tests.py ENGINE_COV_SOURCES).
# Orphan modules: not imported by the packaged app; exercised from repo-root branching tests.
[run]
branch = false
omit =
    app/runtime/branching_turn_executor.py
    # Story runtime host modules are exercised by integration tests, but the engine
    # line gate focuses on HTTP/WS/runtime/content/observability support surfaces.
    app/story_runtime/*.py
    app/narrative/scene_packet_builder.py
    # ASGI entry and large readout projector: covered by dedicated tests / E2E, not the 90% gate slice.
    app/main.py
    app/story_runtime_shell_readout.py
    # Optional Langfuse integration; exercised when backend observability is up (see backend_observability suite).
    app/observability/langfuse_adapter.py

[report]
precision = 2
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
