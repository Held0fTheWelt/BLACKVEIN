# Shared secret used to verify tickets from the Flask backend.
# This must match backend PLAY_SERVICE_SHARED_SECRET.
PLAY_SERVICE_SECRET=replace-me-before-production
# Optional alias if you prefer the backend naming on both services.
# PLAY_SERVICE_SHARED_SECRET=replace-me-before-production

APP_TITLE=World of Shadows Play Service Prototype
PLAY_SERVICE_INTERNAL_API_KEY=replace-me-before-production
RUN_STORE_BACKEND=json
RUN_STORE_URL=

# Optional backend-authored content feed. When configured, published backend experiences
# override matching built-in templates inside the play service.
BACKEND_API_URL=http://127.0.0.1:5000
# Optional explicit feed URL if you do not want to derive it from BACKEND_API_URL.
# BACKEND_CONTENT_FEED_URL=http://127.0.0.1:5000/api/v1/game/content/published
BACKEND_CONTENT_SYNC_ENABLED=true
BACKEND_CONTENT_SYNC_INTERVAL_SECONDS=15
BACKEND_CONTENT_TIMEOUT_SECONDS=10

# ==========================================
# OBSERVABILITY: Langfuse Configuration
# ==========================================
# NOTE: World-Engine fetches these from Backend API at runtime via
# GET /api/v1/admin/observability/status (if BACKEND_API_URL configured).
# These environment variables are used only for local standalone initialization.
# After docker-up.py initializes, Administration Tool governs all settings.

# Enable Langfuse observability (default: false)
# LANGFUSE_ENABLED=false

# Langfuse API base URL (default: https://cloud.langfuse.com)
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Langfuse public key (pk_...)
# LANGFUSE_PUBLIC_KEY=

# Langfuse secret key (sk_...)
# LANGFUSE_SECRET_KEY=

# Langfuse environment label (development|staging|production)
# LANGFUSE_ENVIRONMENT=development

# Release version for tracing
# LANGFUSE_RELEASE=unknown

# Trace sampling rate (0.0-1.0)
# LANGFUSE_SAMPLE_RATE=1.0

# Capture toggles
# LANGFUSE_CAPTURE_PROMPTS=true
# LANGFUSE_CAPTURE_OUTPUTS=true
# LANGFUSE_CAPTURE_RETRIEVAL=false

# Redaction policy (strict|relaxed|none)
# LANGFUSE_REDACTION_MODE=strict
