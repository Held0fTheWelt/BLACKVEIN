{
  "info": {
    "name": "World of Shadows - Smoke Suite",
    "description": "Smaller smoke suite for quick local verification of backend, forum, game bridge, and world-engine health.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Setup & Authentication",
      "description": "",
      "item": [
        {
          "name": "Initialize Run Variables + Backend Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{backendBaseUrl}}{{backendApiPrefix}}/health",
            "description": "Resets collection variables and verifies backend health before the runner continues."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = String(Date.now());",
                  "pm.collectionVariables.clear();",
                  "pm.collectionVariables.set('runSuffix', suffix);",
                  "pm.collectionVariables.set('categorySlug', `postman-category-${suffix}`);",
                  "pm.collectionVariables.set('categoryTitle', `Postman Category ${suffix}`);",
                  "pm.collectionVariables.set('secondaryCategorySlug', `postman-category-b-${suffix}`);",
                  "pm.collectionVariables.set('secondaryCategoryTitle', `Postman Category B ${suffix}`);",
                  "pm.collectionVariables.set('roleName', `postman-role-${suffix}`);",
                  "pm.collectionVariables.set('roleDescription', `Postman role ${suffix}`);",
                  "pm.collectionVariables.set('areaSlug', `postman-area-${suffix}`);",
                  "pm.collectionVariables.set('areaName', `Postman Area ${suffix}`);",
                  "pm.collectionVariables.set('newsSlug', `postman-news-${suffix}`);",
                  "pm.collectionVariables.set('newsTitle', `Postman News ${suffix}`);",
                  "pm.collectionVariables.set('wikiKey', `postman-page-${suffix}`);",
                  "pm.collectionVariables.set('wikiSlug', `postman-page-${suffix}`);",
                  "pm.collectionVariables.set('threadTitle', `Postman Thread ${suffix}`);",
                  "pm.collectionVariables.set('threadTitleB', `Postman Thread B ${suffix}`);",
                  "pm.collectionVariables.set('threadReply', `Postman reply ${suffix}`);",
                  "pm.collectionVariables.set('tagOne', `postman-tag-${suffix}`);",
                  "pm.collectionVariables.set('sloganText', `Postman slogan ${suffix}`);",
                  "pm.collectionVariables.set('disposableUsername', `postman_user_${suffix}`);",
                  "pm.collectionVariables.set('disposableEmail', `postman_${suffix}@example.com`);",
                  "pm.collectionVariables.set('disposablePassword', pm.environment.get('disposablePassword') || 'PostmanPass123!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "    const allowed = [200];",
                  "    pm.test(\"Status code is one of [200]\", function () {",
                  "      pm.expect(allowed).to.include(pm.response.code);",
                  "    });",
                  "    let data = null;",
                  "    const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "    if (contentType.includes('application/json')) {",
                  "      try { data = pm.response.json(); } catch (e) {}",
                  "    }",
                  "",
                  "pm.test(\"Backend health payload contains status\", function () {",
                  "  pm.expect(data).to.be.an('object');",
                  "  pm.expect(data).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
