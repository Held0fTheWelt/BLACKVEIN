        {
          "name": "Register Disposable User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{backendBaseUrl}}{{backendApiPrefix}}/auth/register",
            "description": "Creates a disposable user for admin-side lifecycle tests. May return 409 only if a stale collision exists.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{disposableUsername}}\",\n  \"email\": \"{{disposableEmail}}\",\n  \"password\": \"{{disposablePassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "    const allowed = [201, 409];",
                  "    pm.test(\"Status code is one of [201, 409]\", function () {",
                  "      pm.expect(allowed).to.include(pm.response.code);",
                  "    });",
                  "    let data = null;",
                  "    const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "    if (contentType.includes('application/json')) {",
                  "      try { data = pm.response.json(); } catch (e) {}",
                  "    }",
                  "",
                  "if (pm.response.code === 201 && data) {",
                  "  pm.collectionVariables.set('disposableUserId', String(data.id));",
                  "}"
                ]
              }
            }
          ]
        },
