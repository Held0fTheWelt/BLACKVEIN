          "name": "Users List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 (admin) or 403 (non-admin)', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Body has items, total, page, per_page', function () {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j).to.have.property('items');",
                  "    pm.expect(j.items).to.be.an('array');",
                  "    pm.expect(j).to.have.property('total');",
                  "    pm.expect(j).to.have.property('page');",
