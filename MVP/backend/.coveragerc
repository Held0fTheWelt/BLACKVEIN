[run]
source = app
omit =
    */site-packages/*
    */tests/*
    */__pycache__/*

# Ignore coverage for abstract/auto-generated code
branch = True

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    @overload
    pass  # placeholder implementations

precision = 2
skip_covered = False
skip_empty = True

# Suppress spurious "Couldn't parse" warnings from WSL path conversions
show_missing = True

[html]
directory = htmlcov

[paths]
# Handle both Windows and WSL paths
source =
    app
    */app
    /mnt/c/*/app
    C:\Users\*\*\app

