# Administration tool (.env)
#
# Copy to .env and adjust for your environment.
#
# SECURITY NOTE:
# - Production: set SECRET_KEY explicitly (long random string).
# - Local dev: you can set DEV_SECRETS_OK=1 to allow a one-off random SECRET_KEY.

# Backend base URL (no trailing slash). Local backend:
# BACKEND_API_URL=http://127.0.0.1:5000
BACKEND_API_URL=https://held0fthewelt.pythonanywhere.com/

# Frontend (this app) session/CSRF secret
# SECRET_KEY=change-me-in-production

# Dev convenience: if SECRET_KEY is unset, allow random key for this run
DEV_SECRETS_OK=1

# Optional: Flask behavior
FLASK_ENV=development

# OpenAI API key
OPENAI_API_KEY=this-is-a-test-key