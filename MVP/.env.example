# Required: set these before running (no default secrets in production)
SECRET_KEY=change-me-in-production
# JWT_SECRET_KEY MUST be at least 32 bytes (256 bits) for cryptographic security.
# Generate a strong key: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Example of strong key (43 characters, 32+ bytes UTF-8): TAbv7FzX-_4K8pQ2mN9wR6sYxZ1cVdE3fGhI5jK7lM
JWT_SECRET_KEY=change-me-in-production-jwt

# Optional: use dev fallback secrets and allow seed-dev-user (local only)
# DEV_SECRETS_OK=0

# Flask (run backend from Backend/ with FLASK_APP=run:app)
FLASK_APP=run:app
FLASK_DEBUG=0
PORT=5000

# Database (default: SQLite in Backend/instance/wos.db)
# DATABASE_URI=sqlite:///...

# Backend: legacy paths (/login, /play, …) redirect to player/public frontend. GET / redirects to /backend info pages.
# FRONTEND_URL=http://127.0.0.1:5002
# Optional link target for backend /backend home:
# ADMINISTRATION_TOOL_URL=http://127.0.0.1:5001

# CORS: required when the frontend runs on a different origin than the backend.
# Comma-separated list of allowed origins. Empty = same-origin only (browser blocks cross-origin API calls → "Network error").
# Rules: no spaces around commas, no trailing slashes in origins.
#
# Local frontend and administration tool:
# CORS_ORIGINS=http://127.0.0.1:5002,http://localhost:5002,http://127.0.0.1:5001,http://localhost:5001
#
# Hosted frontend example:
# CORS_ORIGINS=https://your-frontend-app.example.com

# JWT
JWT_ACCESS_TOKEN_EXPIRES=86400

# Session cookies (production HTTPS)
# PREFER_HTTPS=0

# Rate limit
# RATELIMIT_DEFAULT=100 per minute

# Player/public frontend (run from frontend/ with: python run.py)
# FRONTEND_SECRET_KEY=change-me-in-production-frontend
# BACKEND_API_URL=http://127.0.0.1:5000
# FRONTEND_PORT=5002
# PLAY_SERVICE_PUBLIC_URL=http://127.0.0.1:8001

# Administration tool (run from administration-tool/ with: python app.py)
# BACKEND_API_URL=http://127.0.0.1:5000
# PORT=5001

# Play-service integration (backend <-> world-engine)
# PLAY_SERVICE_PUBLIC_URL=http://127.0.0.1:8001
# PLAY_SERVICE_INTERNAL_URL=http://127.0.0.1:8001
# PLAY_SERVICE_SHARED_SECRET=change-me-shared-secret
# PLAY_SERVICE_INTERNAL_API_KEY=change-me-internal-api-key

# Mail (password reset and email verification)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=0
# MAIL_USE_SSL=0
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-password
MAIL_DEFAULT_SENDER=noreply@worldofshadows.local
# Set to 1 to send real mail; 0 = log URLs only (dev)
# MAIL_ENABLED=0

# Registration: 0 = email optional (default), 1 = email required and verification before login
# REGISTRATION_REQUIRE_EMAIL=0

# Email verification (0.0.7): base URL for activation links (no trailing slash).
# If unset, activation links use the request host.
# APP_PUBLIC_BASE_URL=https://your-domain.com
# EMAIL_VERIFICATION_TTL_HOURS=24

# Email verification enforcement (CRITICAL SECURITY SETTING - required in production)
# Set to true to require email verification before login (strongly recommended for production)
# Default: true (for security). False only allowed in testing/development.
REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=true

# Enable email verification feature (must be true if REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=true)
# EMAIL_VERIFICATION_ENABLED=true
