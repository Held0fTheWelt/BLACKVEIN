# Reproducible ai_stack test environment (Python 3.10, same as CI).
# Build from repository root:
#   docker build -f docker/Dockerfile.ai-stack-test -t wos-ai-stack-test .
# Run full ai_stack suite:
#   docker run --rm wos-ai-stack-test
# Run a subset (e.g. GoC regression):
#   docker run --rm wos-ai-stack-test python -m pytest ai_stack/tests/test_goc_phase5_final_mvp_closure.py -q --tb=short
#
# Requires a root .dockerignore to keep the build context lean (see .dockerignore).
FROM python:3.10-bookworm
WORKDIR /workspace

COPY . .
RUN python -m pip install --upgrade pip \
    && python -m pip install -e ./story_runtime_core \
    && python -m pip install -e "./ai_stack[test]" \
    && python -c "import langchain_core, langgraph; import ai_stack.langgraph_runtime"

ENV PYTHONPATH=/workspace
CMD ["python", "-m", "pytest", "ai_stack/tests", "-q", "--tb=short"]
