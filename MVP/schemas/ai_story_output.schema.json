{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Story Output Schema",
  "description": "Canonical schema for structured AI story model output",
  "type": "object",
  "required": [
    "scene_interpretation",
    "detected_triggers",
    "proposed_state_deltas",
    "dialogue_impulses",
    "conflict_vector"
  ],
  "properties": {
    "scene_interpretation": {
      "type": "string",
      "description": "Narrative interpretation of current scene state"
    },
    "detected_triggers": {
      "type": "array",
      "description": "Triggers from the module's trigger set that are active",
      "items": {
        "type": "string"
      }
    },
    "proposed_state_deltas": {
      "type": "object",
      "description": "Proposed state changes (characters and relationships)"
    },
    "dialogue_impulses": {
      "type": "array",
      "description": "Proposed dialogue and character actions",
      "items": {
        "type": "string"
      }
    },
    "conflict_vector": {
      "type": "string",
      "description": "Current direction and intensity of conflict"
    },
    "confidence": {
      "type": "number",
      "description": "Model confidence in this proposal (0–1)",
      "minimum": 0,
      "maximum": 1
    },
    "uncertainty": {
      "type": "string",
      "description": "Optional model uncertainty notes"
    }
  }
}
