{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "State Delta Schema",
  "description": "Canonical schema for proposed and applied state changes",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "character_name": {
      "type": "object",
      "description": "Per-character state changes (one property per character name)",
      "properties": {
        "emotional_state": {
          "type": "integer",
          "description": "Character emotional state (0–100)",
          "minimum": 0,
          "maximum": 100
        },
        "escalation_level": {
          "type": "integer",
          "description": "Escalation level (0–100)",
          "minimum": 0,
          "maximum": 100
        },
        "engagement": {
          "type": "integer",
          "description": "Engagement level (0–100)",
          "minimum": 0,
          "maximum": 100
        },
        "moral_defense": {
          "type": "integer",
          "description": "Moral defense strength (0–100)",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "relationship_axis": {
      "type": "object",
      "description": "Per-relationship state changes (one property per axis name)",
      "properties": {
        "stability": {
          "type": "integer",
          "description": "Relationship stability (0–100)",
          "minimum": 0,
          "maximum": 100
        },
        "dominance_shift": {
          "type": "integer",
          "description": "Dominance shift (-5 to +5)",
          "minimum": -5,
          "maximum": 5
        }
      }
    }
  }
}
