{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://world-of-shadows.local/schemas/goc_g9_experience_score_matrix_v1.json",
  "title": "GoC G9 experience score matrix (roadmap §6.9)",
  "description": "Human score sheet shape. Scores 1–5; null allowed until filled. Canonical scenario set is fixed and non-substitutable.",
  "type": "object",
  "required": [
    "schema",
    "roadmap_reference",
    "criteria",
    "scenarios"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "goc_g9_experience_score_matrix_v1"
    },
    "roadmap_reference": {
      "type": "string",
      "minLength": 1
    },
    "audit_run_id": {
      "type": "string"
    },
    "scorer_role": {
      "type": "string"
    },
    "scored_at_utc": {
      "type": "string"
    },
    "criteria": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "dramatic_responsiveness",
          "truth_consistency",
          "character_credibility",
          "conflict_continuity",
          "graceful_degradation"
        ]
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "scenario_id",
          "failure_oriented",
          "scores"
        ],
        "additionalProperties": true,
        "properties": {
          "scenario_id": {
            "type": "string",
            "enum": [
              "goc_roadmap_s1_direct_provocation",
              "goc_roadmap_s2_deflection_brevity",
              "goc_roadmap_s3_pressure_escalation",
              "goc_roadmap_s4_misinterpretation_correction",
              "goc_roadmap_s5_primary_failure_fallback",
              "goc_roadmap_s6_retrieval_heavy"
            ]
          },
          "failure_oriented": {
            "type": "boolean",
            "description": "Roadmap §6.9: graceful degradation ≥ 3.5 applies only to failure-oriented scenarios (typically s5)."
          },
          "automated_trace_anchor": {
            "type": "string"
          },
          "scores": {
            "type": "object",
            "required": [
              "dramatic_responsiveness",
              "truth_consistency",
              "character_credibility",
              "conflict_continuity",
              "graceful_degradation"
            ],
            "additionalProperties": false,
            "properties": {
              "dramatic_responsiveness": {
                "type": ["number", "null"],
                "minimum": 1,
                "maximum": 5
              },
              "truth_consistency": {
                "type": ["number", "null"],
                "minimum": 1,
                "maximum": 5
              },
              "character_credibility": {
                "type": ["number", "null"],
                "minimum": 1,
                "maximum": 5
              },
              "conflict_continuity": {
                "type": ["number", "null"],
                "minimum": 1,
                "maximum": 5
              },
              "graceful_degradation": {
                "type": ["number", "null"],
                "minimum": 1,
                "maximum": 5
              }
            }
          },
          "cell_rationale": {
            "type": "object"
          }
        }
      }
    },
    "threshold_check": {
      "type": "object"
    }
  }
}
