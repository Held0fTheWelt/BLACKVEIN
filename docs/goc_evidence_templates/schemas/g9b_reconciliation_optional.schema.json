{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://world-of-shadows.local/schemas/goc_g9b_reconciliation_optional_v1.json",
  "title": "GoC G9B optional reconciliation summary",
  "description": "Optional narrative or agreed summary. Must not replace raw score sheets or delta records.",
  "type": "object",
  "required": [
    "schema",
    "roadmap_reference",
    "must_not_replace_raw",
    "audit_run_id"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "goc_g9b_reconciliation_optional_v1"
    },
    "roadmap_reference": {
      "type": "string",
      "minLength": 1
    },
    "audit_run_id": {
      "type": "string"
    },
    "must_not_replace_raw": {
      "type": "boolean",
      "const": true
    },
    "summary": {
      "type": "string"
    },
    "linked_raw_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths or URIs to raw sheets and delta record that remain authoritative."
    }
  }
}
