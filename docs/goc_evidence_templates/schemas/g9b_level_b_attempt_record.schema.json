{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://world-of-shadows.local/schemas/goc_g9b_level_b_attempt_record_v1.json",
  "title": "GoC G9B Level B attempt status record",
  "description": "Machine-readable status for a Level B independence attempt on a fixed G9 audit_run_id. Incomplete or failed attempts must not be upgraded to level_b_capable without evidentiary independence.",
  "type": "object",
  "required": [
    "schema",
    "roadmap_reference",
    "audit_run_id",
    "level_b_attempt_status",
    "closure_level_status_gate_g9b_reported"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "goc_g9b_level_b_attempt_record_v1"
    },
    "roadmap_reference": {
      "type": "string",
      "minLength": 1
    },
    "audit_run_id": {
      "type": "string",
      "minLength": 1
    },
    "level_b_attempt_status": {
      "type": "string",
      "enum": ["incomplete", "failed_insufficient_independence", "complete_level_b_evidence_ready"]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "evaluator_a": {
      "type": "object",
      "additionalProperties": true
    },
    "evaluator_b": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "expected_evaluator_b_artifacts_when_complete": {
      "type": "object",
      "additionalProperties": true
    },
    "closure_level_status_gate_g9b_reported": {
      "type": "string",
      "enum": ["level_a_capable", "level_b_capable"]
    },
    "level_b_capable_evidence_bar": {
      "type": "string"
    }
  }
}
